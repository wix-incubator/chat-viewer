{
  "name": "chat-viewer",
  "version": "0.2.0",
  "description": "A library for rendering chats with virtualization",
  "type": "module",
  "license": "MIT",
  "packageManager": "yarn@4.10.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/wix-incubator/chat-viewer.git"
  },
  "keywords": [
    "react",
    "chat",
    "viewer",
    "virtualization",
    "virtual-scroll"
  ],
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "yarn build:lib && yarn build:demo",
    "build:lib": "tsc --p ./tsconfig.esm.json && vite build",
    "build:docs": "typedoc",
    "build:demo": "vite build --mode demo",
    "build:website": "yarn build:docs && yarn build:demo",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "peerDependencies": {
    "react": "^19.0.7",
    "react-dom": "^19.0.7"
  },
  "dependencies": {
    "virtua": "0.48.8"
  },
  "devDependencies": {
    "@faker-js/faker": "9.9.0",
    "@types/node": "24.0.12",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "husky": "9.1.7",
    "lint-staged": "15.2.11",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "react": "19.0.7",
    "react-dom": "19.0.7",
    "typedoc": "0.28.7",
    "typedoc-plugin-markdown": "4.7.0",
    "typescript": "5.8.3",
    "vite": "7.3.5",
    "vite-plugin-dts": "4.5.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,md,html,css,yml,yaml}": [
      "oxfmt --write"
    ],
    "*.{ts,tsx}": [
      "oxlint --fix"
    ]
  }
}
